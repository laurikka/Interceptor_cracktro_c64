        name    "stdswitcher4"
        label   "Transform"
        grouptag { "sidefx::switcher" "stdswitcher" }

        parm {
            name    "xOrd"
            baseparm
            label   "Transform Order"
            joinnext
            export  none
        }
        parm {
            name    "rOrd"
            baseparm
            label   "Rotate Order"

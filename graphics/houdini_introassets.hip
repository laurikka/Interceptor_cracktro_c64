            export  none
        }
        parm {
            name    "vex_multithread"
            baseparm
            label   "Enable Multithreading"
            export  none
        }
    }

    group {
        name    "stdswitcher3_1"
        label   "Attribute Bindings"

        parm {
            name    "vex_precision"
            baseparm
            label   "VEX Precision"
            export  none
        }
        parm {
            name    "autobind"
            baseparm
            label   "Autobind by Name"
            export  none
        }
        multiparm {
            name    "bindings"
            label    "Number of Bindings"
            baseparm
            default 0
            parmtag { "multistartoffset" "1" }

            parm {
                name    "bindname#"
                baseparm
                label   "Attribute Name"
                export  none
            }
            parm {

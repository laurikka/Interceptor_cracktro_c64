        }
    }

    group {
        name    "stdswitcher3_1"
        label   "Attribute Bindings"

        parm {
            name    "vex_precision"
            baseparm
            label   "VEX Precision"
            export  none
        }
        parm {
            name    "autobind"
            baseparm
            label   "Autobind by Name"
            export  none

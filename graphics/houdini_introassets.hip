            baseparm
            label   "Snippet"
            export  none
        }
        parm {
            name    "vex_strict"
            baseparm
            label   "Enforce Prototypes"
            export  none
        }
        parm {
            name    "vex_exportlist"
            baseparm
            label   "Attributes to Create"
            export  none
        }
        parm {
